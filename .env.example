# P3 Lending Protocol environment template
# Copy to .env.local for local development. Do not commit real secrets.

# --- Frontend required ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_BACKEND_URL=http://localhost:3001

# --- Frontend optional ---
VITE_API_KEY=
VITE_GOOGLE_CLIENT_ID=
VITE_COINGECKO_API_KEY=
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-5-codex
VITE_STRIPE_DONATE_URL=https://buy.stripe.com/14A6oH5Nb72t38K1VEaIM00
VITE_STRIPE_PAYOUTS_ENABLED=false
VITE_BTC_WITHDRAWALS_ENABLED=false
VITE_BTC_WITHDRAW_PROVIDER_URL=
VITE_BTC_WITHDRAW_PROVIDER_TOKEN=
VITE_PLAID_CLIENT_ID=
VITE_PLAID_SECRET=
VITE_PLAID_ENV=sandbox
VITE_BETA_FEATURE_FLAGS={}

# --- Frontend legacy compatibility (optional) ---
API_KEY=
GOOGLE_CLIENT_ID=
COINGECKO_API_KEY=

# --- Backend required ---
PORT=5000
FRONTEND_URL=http://localhost:5173
SUPABASE_URL=https://your-project-ref.supabase.co
# Optional: if omitted, backend falls back to SUPABASE_SERVICE_ROLE_KEY for RLS client init.
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TAX_ENABLED=true
STRIPE_SERVICE_FEE_PERCENT=0.03
STRIPE_SERVICE_FEE_FIXED_USD=3
STRIPE_SERVICE_FEE_TAXABLE=false
STRIPE_SERVICE_DEFAULT_TAX_CODE=
STRIPE_SERVICE_CATALOG_JSON=
STRIPE_IDENTITY_ENABLED=true
STRIPE_IDENTITY_REQUIRE_LIVE_CAPTURE=true
STRIPE_IDENTITY_REQUIRE_MATCHING_SELFIE=true
STRIPE_IDENTITY_REQUIRE_ID_NUMBER=true
STRIPE_IDENTITY_ALLOWED_DOC_TYPES=passport,id_card,driving_license
STRIPE_IDENTITY_VERIFICATION_FLOW_ID=
STATEMENT_SIGNING_SECRET=
COINGECKO_API_KEY=
COINGECKO_API_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_CACHE_SECONDS=20
TRANSACTION_FEE_PERCENT=0.03
TRANSACTION_FEE_FIXED_USD=3
TRADING_PROVIDER_ENABLED=true
STRIPE_PAYOUTS_ENABLED=false
BTC_WITHDRAWALS_ENABLED=false
BTC_WITHDRAW_PROVIDER_URL=
BTC_WITHDRAW_PROVIDER_TOKEN=
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_COUNTRY_CODES=US
PLAID_PRODUCTS=auth,identity,transactions
PLAID_REDIRECT_URI=
PLAID_WEBHOOK_URL=
SMTP_HOST=smtp.protonmail.ch
SMTP_PORT=587
SMTP_USER=admin@p3lending.space
SMTP_PASS=
SMTP_FROM=admin@p3lending.space
SMTP_SECURE=false

# --- Blockchain optional (backend) ---
ETH_RPC_URL=http://127.0.0.1:8545
P3_PROTOCOL_ADDRESS=0x0000000000000000000000000000000000000000

NODE_ENV=development
