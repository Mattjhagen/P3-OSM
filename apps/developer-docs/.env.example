# P3 Developer Docs – local testing (Netlify Dev)
# Copy to .env and fill in real values. Do not commit .env.

# Required for auth + referral links (same as main app)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Required for /api/create-checkout (Stripe subscription checkout)
STRIPE_SECRET_KEY=sk_test_your_secret_key

# Required for create-checkout to verify JWT (Netlify env)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
